---
import type { HTMLAttributes } from "astro/types";

import { dropdownItem } from "./variants";

type Props = HTMLAttributes<"div"> & {
  /**
   * Whether the item is inset (has left padding)
   */
  inset?: boolean;
  /**
   * Whether the item is disabled
   */
  disabled?: boolean;
};

const { class: className, inset = false, disabled = false, ...rest } = Astro.props;
---

<div
  class={dropdownItem({ inset, disabled, class: ["starwind-dropdown-sub-trigger", className] })}
  role="menuitem"
  aria-haspopup="true"
  aria-expanded="false"
  tabindex={disabled ? "-1" : "0"}
  data-disabled={disabled ? "true" : undefined}
  data-sub-trigger
  {...rest}
  data-slot="dropdown-item"
>
  <slot />
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="ml-auto size-4"
    aria-hidden="true"
  >
    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
    <path d="M9 6l6 6l-6 6"></path>
  </svg>
</div>
